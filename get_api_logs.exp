#!/usr/bin/expect -f
set timeout -1
set password "12345678"

spawn ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null user@mail.irbis.ua
expect {
    "password:" {
        send "$password\r"
    }
}

expect "$ "
send "tail -n 100 /srv/projects/velnox/api/storage/logs/laravel.log\r"
expect "$ "
send "exit\r"
expect eof
