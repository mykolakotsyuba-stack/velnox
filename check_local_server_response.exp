#!/usr/bin/expect -f
set timeout -1
set password "12345678"

spawn ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null user@mail.irbis.ua
expect {
    "password:" {
        send "$password\r"
    }
}

expect "$ "
send "curl -s http://127.0.0.1:8505/uk/products/agro | grep \"data-label\" | head -n 5\r"
expect "$ "
send "exit\r"
expect eof
