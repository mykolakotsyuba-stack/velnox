#!/usr/bin/expect -f
set timeout -1
set password "12345678"

# 1. SSH and check git status on API
spawn ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null user@mail.irbis.ua
expect {
    "password:" {
        send "$password\r"
    }
}

expect "$ "
send "cd /srv/projects/velnox/api && git status\r"
expect "$ "
send "cd /srv/projects/velnox/frontend && git status\r"
expect "$ "
send "exit\r"
expect eof
