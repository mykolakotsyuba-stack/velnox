#!/usr/bin/expect -f
set password "12345678"
spawn ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null user@mail.irbis.ua
expect "password:" { send "$password\r" }
expect "$ " { send "cat /srv/projects/velnox/frontend/.env.local 2>/dev/null || cat /srv/projects/velnox/frontend/.env\r" }
expect "$ " { send "exit\r" }
expect eof
