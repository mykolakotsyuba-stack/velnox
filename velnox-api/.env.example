APP_NAME="VELNOX API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

# PostgreSQL (рекомендовано для JSONB)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=velnox_db
DB_USERNAME=postgres
DB_PASSWORD=

# Frontened URL (для CORS)
FRONTEND_URL=http://localhost:3000

# API токен для імпорту з 1С
IMPORT_API_TOKEN=your-secret-token-here

# Filament admin
FILAMENT_BRAND_NAME="VELNOX Admin"
