#!/usr/bin/expect -f
set timeout -1
set password "12345678"

spawn ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null user@mail.irbis.ua
expect {
    "password:" {
        send "$password\r"
    }
}

expect "$ "
send "cat /etc/systemd/system/velnox-frontend.service\r"
expect "$ "
send "exit\r"
expect eof
